{
  "database": {
    "migrations": {
      "apply": true
    }
  },
  "logging": {
    "level": "debug",
    "formatter": "pretty",
    "formatters": {
      "pretty": {
        "levelColors": {
          "debug": "blue",
          "info": "white",
          "warning": "yellow",
          "error": "red",
          "fatal": "magenta"
        },
        "levelStyle": ["bold"],
        "categoryWidth": 0,
        "categoryStyle": [],
        "categoryColor": "cyan",
        "messageStyle": [],
        "messageColor": "white"
      }
    }
  },
  "redirect": {
    "expiry": "10 seconds"
  }
}
