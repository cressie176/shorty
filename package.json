{
  "name": "shorty",
  "version": "1.0.0",
  "description": "URL shortener service with PostgreSQL backend",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx --watch index.ts",
    "test": "APP_ENV=test node --test --test-concurrency=1 --test-timeout=1000 --import tsx test/**/*.test.ts",
    "test:match": "./scripts/test",
    "build": "tsc",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "db:migrate": "node --import tsx --eval \"import('./src/migrate.js')\""
  },
  "keywords": [
    "url shortener",
    "typescript",
    "postgresql"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@hono/node-server": "^1.19.7",
    "@logtape/logtape": "^1.3.5",
    "hono": "^4.11.1",
    "luxon": "^3.7.2",
    "marv": "^6.1.0",
    "marv-pg-driver": "^5.0.0",
    "nanoid": "^5.1.6",
    "pg": "^8.16.3",
    "ramda": "^0.32.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.10",
    "@logtape/pretty": "^1.3.5",
    "@ngneat/falso": "^8.0.2",
    "@types/luxon": "^3.7.1",
    "@types/marv": "^6.0.5",
    "@types/marv-pg-driver": "^4.0.3",
    "@types/node": "^25.0.3",
    "@types/pg": "^8.16.0",
    "@types/ramda": "^0.31.1",
    "immer": "^11.1.0",
    "lefthook": "^2.0.12",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
